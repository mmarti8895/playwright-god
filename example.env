# playwright-god LLM Provider Configuration
# Copy this file to .env and fill in your values.
# Command-line arguments (e.g., --provider, --model) will override these settings.

# =============================================================================
# LLM Provider Selection
# =============================================================================
# Which LLM provider to use: openai, anthropic, gemini, ollama, or template
# If not set, auto-detection checks for API keys in this order:
#   1. OPENAI_API_KEY -> openai
#   2. ANTHROPIC_API_KEY -> anthropic
#   3. GOOGLE_API_KEY -> gemini
#   4. Falls back to offline "template" generator
PLAYWRIGHT_GOD_PROVIDER=

# =============================================================================
# Model Selection (optional)
# =============================================================================
# Override the default model for your chosen provider.
# Defaults:
#   - openai: gpt-4o
#   - anthropic: claude-3-5-sonnet-20241022
#   - gemini: gemini-1.5-pro
#   - ollama: llama3
PLAYWRIGHT_GOD_MODEL=

# =============================================================================
# API Keys
# =============================================================================
# Set the API key for your chosen provider.
# Only the key for your selected provider is required.

# OpenAI API key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Anthropic API key (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=

# Google AI API key for Gemini (https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=

# =============================================================================
# Ollama Configuration (local models)
# =============================================================================
# Base URL for Ollama server (only used when provider is "ollama")
OLLAMA_URL=http://localhost:11434

# =============================================================================
# Test Credentials (referenced in generated tests)
# =============================================================================
# These are used as placeholders in generated Playwright tests.
# The generator will reference process.env.TEST_USERNAME etc. instead of
# hardcoding credentials.
TEST_USERNAME=
TEST_PASSWORD=
